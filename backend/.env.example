AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_GROUP=
PORT=3001

# Set to true to serve hardcoded demo data instead of calling Azure.
# Lets you run the dashboard without any Azure credentials.
MOCK_DATA=false

# Anthropic API key for the AI Cost Analyst (natural-language Q&A over your
# cost data). Get one at https://console.anthropic.com/. Works in mock mode too.
ANTHROPIC_API_KEY=
